{
  "rules": {
    ".read": false,
    ".write": false,

    "users": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "products": {
      ".read": true,
      "$productId": {
        ".read": true,
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
      }
    },

    "product_details": {
      ".read": true,
      "$productId": {
        ".read": true,
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
      }
    },

    "categories": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },

    "orders": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "contacts": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".write": true
    },

    "reviews": {
      ".read": true,
      ".write": "auth != null"
    },

    "notifications": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'kitchen' || root.child('users').child(auth.uid).child('role').val() === 'shipper' || root.child('users').child(auth.uid).child('role').val() === 'admin')"
    }
  }
}
