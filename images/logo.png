<svg width="200" height="200" xmlns="http://www.w3.org/2000/svg">
  <!-- Background circle -->
  <circle cx="100" cy="100" r="95" fill="#111111" stroke="#ff7a00" stroke-width="4"/>
  
  <!-- Pizza slice illustration -->
  <path d="M 100 30 L 170 100 L 100 100 Z" fill="#ff7a00" opacity="0.9"/>
  <path d="M 100 30 L 100 100 L 30 100 Z" fill="#ff7a00" opacity="0.7"/>
  
  <!-- Pizza toppings (pepperoni) -->
  <circle cx="120" cy="80" r="8" fill="#8B0000"/>
  <circle cx="90" cy="70" r="8" fill="#8B0000"/>
  <circle cx="110" cy="100" r="8" fill="#8B0000"/>
  
  <!-- Text "N" -->
  <text x="100" y="150" font-family="Arial, sans-serif" font-size="60" font-weight="bold" fill="#ff7a00" text-anchor="middle">N</text>
</svg>
